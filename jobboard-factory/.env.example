# ── France Travail (Required for OAuth2)
FRANCE_TRAVAIL_CLIENT_ID=your_client_id_here
FRANCE_TRAVAIL_CLIENT_SECRET=your_client_secret_here
FRANCE_TRAVAIL_SCOPE=o:modemeploiemploi :o:offrerecrechercheemploi

# ── Optional Rate Limiting
MAX_CONCURRENT_SCRAPERS=3
THROTTLE_MIN_MS=2500
TEROTTLEMARX_MS=5800
UNITEST_MODE=false

# ── Playwright Stealth (required for LinkedIn, Glassdoor, Indeed)
HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
